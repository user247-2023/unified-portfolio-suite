# Real-Time Log Analytics - config template. Copy to .env. Never commit real values.
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_TOPIC=logs.raw
KAFKA_DLQ_TOPIC=logs.deadletter
KAFKA_GROUP_ID=log-processor

CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
# INSERT-only user for the processor (least privilege)
CLICKHOUSE_USER=ingest
CLICKHOUSE_PASSWORD=change-me
CLICKHOUSE_DB=logs

BATCH_SIZE=1000
FLUSH_INTERVAL_SECONDS=2
