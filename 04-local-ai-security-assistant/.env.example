# Local AI Security Assistant - config template. Copy to .env.
# All values point at LOCAL services; nothing is sent to a third party.

# Local Ollama endpoint
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Local embedding model (downloaded once by sentence-transformers)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Where the local FAISS index is persisted
INDEX_PATH=./.index
