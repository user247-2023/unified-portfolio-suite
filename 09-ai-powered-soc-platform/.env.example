# AI-Powered SOC Platform - config template. Copy to .env. Never commit secrets.

# --- Ingestion auth (REQUIRED to enable /ingest; fail-closed if unset) -------
# Generate with: openssl rand -hex 32
INGEST_API_KEY=replace-with-a-strong-random-key

# --- Correlation tuning ------------------------------------------------------
CORRELATION_WINDOW_SECONDS=300
BRUTE_FORCE_THRESHOLD=5
PORT_SCAN_THRESHOLD=15

# --- Triage ------------------------------------------------------------------
AUTO_ESCALATE_SCORE=80

# --- Service wiring ----------------------------------------------------------
BIND_HOST=0.0.0.0
BIND_PORT=8000

# --- Dashboard (build-time) --------------------------------------------------
VITE_API_URL=http://localhost:8000
