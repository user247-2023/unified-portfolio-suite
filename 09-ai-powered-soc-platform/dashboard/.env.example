# SIEM dashboard build-time config. Copy to .env(.local). Vite only exposes
# variables prefixed with VITE_ to the browser bundle.

# Ingestion API base URL the dashboard reads incidents from.
VITE_API_URL=http://localhost:8000

# Optional machine API key for local testing ONLY. In production the dashboard
# should authenticate the USER (SSO) and proxy to the API server-side instead.
VITE_API_KEY=

# Set to 1 to force demo data (renders a populated dashboard with no backend).
VITE_DEMO=0
