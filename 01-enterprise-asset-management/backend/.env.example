# EAMS backend environment template.
# Copy to .env and fill in real values. .env is git-ignored repo-wide.
# NEVER commit real secrets.

# Postgres
POSTGRES_USER=eams
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=eams

# Full connection string used by Prisma / the API
DATABASE_URL=postgresql://eams:change-me-strong-password@db:5432/eams

# Signing key for JWT access tokens. Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-32-byte-random-hex

# Runtime
NODE_ENV=development
PORT=4000
